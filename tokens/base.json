{
  "space": {
    "$description": "A 4px base grid.",
    "$type": "dimension",
    "0": { "$value": "0" },
    "2xs": { "$value": "0.25rem" },
    "xs": { "$value": "0.5rem" },
    "sm": { "$value": "0.75rem" },
    "md": { "$value": "1rem" },
    "lg": { "$value": "1.5rem" },
    "xl": { "$value": "2rem" },
    "2xl": { "$value": "3rem" },
    "3xl": { "$value": "4rem" },
    "4xl": { "$value": "6rem" }
  },
  "font": {
    "$description": "Font family stacks.",
    "$type": "fontFamily",
    "display": { "$value": "Hanken Grotesk Variable, system-ui, -apple-system, Segoe UI, sans-serif" },
    "sans": { "$value": "Hanken Grotesk Variable, system-ui, -apple-system, Segoe UI, sans-serif" },
    "mono": { "$value": "Geist Mono Variable, ui-monospace, SF Mono, menlo, monospace" }
  },
  "text": {
    "$description": "A 1.25 modular type scale on a 16px base. `display` is a fluid clamp.",
    "$type": "dimension",
    "xs": { "$value": "0.75rem" },
    "sm": { "$value": "0.875rem" },
    "base": { "$value": "1rem" },
    "md": { "$value": "1.125rem" },
    "lg": { "$value": "1.25rem" },
    "xl": { "$value": "1.5rem" },
    "2xl": { "$value": "1.875rem" },
    "3xl": { "$value": "2.25rem" },
    "4xl": { "$value": "3rem" },
    "5xl": { "$value": "4rem" },
    "6xl": { "$value": "5.25rem" },
    "display": { "$value": "clamp(2.75rem, 9vw, 5.25rem)", "$type": "other" }
  },
  "weight": {
    "$type": "fontWeight",
    "regular": { "$value": "400" },
    "medium": { "$value": "500" },
    "semibold": { "$value": "600" },
    "bold": { "$value": "700" },
    "black": { "$value": "900" }
  },
  "leading": {
    "$description": "Line heights (unitless).",
    "$type": "number",
    "none": { "$value": "1" },
    "tight": { "$value": "1.1" },
    "snug": { "$value": "1.3" },
    "normal": { "$value": "1.55" },
    "relaxed": { "$value": "1.75" }
  },
  "tracking": {
    "$description": "Letter spacing in em.",
    "$type": "dimension",
    "tightest": { "$value": "-0.03em" },
    "tight": { "$value": "-0.01em" },
    "normal": { "$value": "0" },
    "wide": { "$value": "0.04em" },
    "wider": { "$value": "0.14em" }
  },
  "radius": {
    "$type": "dimension",
    "none": { "$value": "0" },
    "sm": { "$value": "0.125rem" },
    "md": { "$value": "0.125rem" },
    "lg": { "$value": "0.25rem" },
    "xl": { "$value": "0.375rem" },
    "full": { "$value": "9999px" }
  },
  "z": {
    "$description": "Named stacking order.",
    "$type": "number",
    "base": { "$value": "0" },
    "raised": { "$value": "10" },
    "dropdown": { "$value": "1000" },
    "sticky": { "$value": "1100" },
    "overlay": { "$value": "1200" },
    "modal": { "$value": "1300" },
    "popover": { "$value": "1400" },
    "toast": { "$value": "1500" }
  },
  "duration": {
    "$type": "duration",
    "instant": { "$value": "80ms" },
    "fast": { "$value": "120ms" },
    "base": { "$value": "200ms" },
    "slow": { "$value": "320ms" }
  },
  "ease": {
    "$type": "cubicBezier",
    "standard": { "$value": "cubic-bezier(0.2, 0, 0, 1)" },
    "emphasized": { "$value": "cubic-bezier(0.3, 0, 0, 1)" },
    "exit": { "$value": "cubic-bezier(0.4, 0, 1, 1)" }
  },
  "motif": {
    "$description": "Spec Sheet technical-drawing dimensions.",
    "$type": "dimension",
    "grid": { "$value": "2rem" },
    "grid-fine": { "$value": "1.125rem" },
    "rule-width": { "$value": "1.5px" },
    "mark-size": { "$value": "14px" },
    "dot-radius": { "$value": "1.25px" }
  }
}
