{
  "color": {
    "$description": "Semantic color roles for the dark (dev mode) theme.",
    "$type": "color",
    "bg": { "$value": "{palette.neutral.950}" },
    "surface": { "$value": "{palette.neutral.850}" },
    "surface-raised": { "$value": "{palette.neutral.800}" },
    "text": { "$value": "{palette.neutral.50}" },
    "text-muted": { "$value": "{palette.neutral.300}" },
    "text-subtle": { "$value": "{palette.neutral.400}" },
    "text-on-primary": { "$value": "{palette.neutral.950}" },
    "border": { "$value": "{palette.neutral.700}" },
    "border-strong": { "$value": "{palette.neutral.400}" },
    "border-focus": { "$value": "{palette.neutral.50}" },
    "primary": { "$value": "{palette.neutral.50}" },
    "primary-hover": { "$value": "{palette.neutral.0}" },
    "primary-active": { "$value": "{palette.neutral.200}" },
    "primary-bg": { "$value": "rgba(250, 248, 242, 0.12)" },
    "primary-bg-strong": { "$value": "rgba(250, 248, 242, 0.2)" },
    "accent-text": { "$value": "{palette.signal.400}" },
    "signal": { "$value": "{palette.signal.450}" },
    "text-on-signal": { "$value": "{palette.neutral.950}" },
    "danger": { "$value": "{palette.danger.400}" },
    "danger-solid": { "$value": "{palette.danger.600}" },
    "danger-solid-hover": { "$value": "{palette.danger.700}" },
