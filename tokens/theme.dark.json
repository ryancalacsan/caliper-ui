  "shadow": {
    "$description": "Deepened single-layer shadows for the dark theme, where plain drop shadows would vanish.",
    "$type": "shadow",
    "sm": { "$value": "0 1px 2px rgb(0 0 0 / 40%)" },
    "md": { "$value": "0 4px 16px rgb(0 0 0 / 50%)" },
    "lg": { "$value": "0 16px 40px rgb(0 0 0 / 60%)" }
