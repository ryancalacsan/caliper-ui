    "focus-ring": { "$value": "{palette.signal.450}" },
    "overlay": { "$value": "rgba(0, 0, 0, 0.6)" },
    "inverse-surface": { "$value": "{palette.neutral.50}" },
    "inverse-text": { "$value": "{palette.neutral.950}" },
    "grid-line": { "$value": "{palette.neutral.700}" },
    "rule": { "$value": "{palette.neutral.400}" },
    "mark": { "$value": "{palette.signal.450}" }
