{
  "name": "@ryancalacsan/caliper-ui",
  "version": "0.10.0",
  "type": "module",
  "description": "An accessible React component library and design system, built with hand-written SCSS and design tokens. Two themes, WCAG 2.2 AA, RSC-ready.",
  "license": "MIT",
  "author": "Ryan Calacsan",
  "homepage": "https://caliper-ui.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryancalacsan/caliper-ui.git"
  },
  "bugs": {
    "url": "https://github.com/ryancalacsan/caliper-ui/issues"
  },
  "keywords": [
    "react",
    "components",
    "component-library",
    "design-system",
    "design-tokens",
    "accessibility",
    "wcag",
    "scss",
    "ui"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    },
    "./styles.css": "./lib/caliper.css",
    "./tokens.css": "./lib/tokens.css",
    "./package.json": "./package.json"
  },
  "files": [
    "lib"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "rm -rf lib && vite build --config vite.lib.config.ts && node scripts/build-fonts.mjs && sass src/styles/tokens.scss lib/tokens.css --no-source-map --style=expanded && node scripts/check-lib.mjs",
    "prepublishOnly": "npm run build:lib",
    "vercel-build": "npm run build && STORYBOOK_BASE_PATH=/storybook/ storybook build -o dist/storybook",
    "preview": "vite preview",
    "lint": "oxlint && stylelint \"src/**/*.scss\"",
    "lint:js": "oxlint",
    "lint:css": "stylelint \"src/**/*.scss\"",
    "lint:css:fix": "stylelint \"src/**/*.scss\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,md,json}\" \"tests/**/*.ts\" \"*.{ts,md,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,md,json}\" \"tests/**/*.ts\" \"*.{ts,md,json}\"",
    "typecheck": "tsc -b --noEmit",
    "test:contrast": "node scripts/check-contrast.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "changeset": "changeset",
    "release": "npm run build:lib && changeset publish"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@chromatic-com/storybook": "^5.2.1",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource-variable/hanken-grotesk": "^5.2.8",
    "@playwright/test": "^1.61.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "oxlint": "^1.69.0",
    "playwright": "^1.61.0",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rollup-preserve-directives": "^1.1.3",
    "sass": "^1.101.0",
    "storybook": "^10.4.6",
    "stylelint": "^17.13.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9"
  }
}
